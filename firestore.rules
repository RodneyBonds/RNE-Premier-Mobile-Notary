rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "Rodbonds1169@gmail.com" || request.auth.token.email == "adminrodney@rnepremiermobilenotary.com");
    }

    // Admin status
    match /adminStatus/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Chat sessions
    match /chatSessions/{sessionId} {
      allow read: if isAdmin() || true; // Allow visitor to read their own session
      allow create: if true; // Visitors can start a chat
      allow update: if isAdmin() || true; // Allow visitors to update their session status
      allow delete: if isAdmin();
    }

    match /chatSessions/{sessionId}/messages/{messageId} {
      allow read: if isAdmin() || true; // Allow visitor to read their own messages
      allow create: if true; // Visitors can send messages
      allow delete: if isAdmin();
    }
  }
}
